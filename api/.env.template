# Застосунок
APP_CONFIG__APP__NAME=FastAPI Auth
APP_CONFIG__APP__VERSION=1.0.0
APP_CONFIG__APP__DEBUG=true
APP_CONFIG__APP__ENVIRONMENT=development

# Сервер
APP_CONFIG__SERVER__HOST=0.0.0.0
APP_CONFIG__SERVER__PORT=8000
APP_CONFIG__SERVER__RELOAD=true

# База даних
APP_CONFIG__DB__HOST=localhost
APP_CONFIG__DB__PORT=5432
APP_CONFIG__DB__NAME=auth_db
APP_CONFIG__DB__USER=postgres
APP_CONFIG__DB__PASSWORD=postgres
APP_CONFIG__DB__ECHO=false
APP_CONFIG__DB__POOL_SIZE=5
APP_CONFIG__DB__MAX_OVERFLOW=10
APP_CONFIG__DB__POOL_TIMEOUT=30
APP_CONFIG__DB__POOL_RECYCLE=3600

# JWT
APP_CONFIG__JWT__SECRET_KEY=your-secret-key-change-in-production
APP_CONFIG__JWT__ALGORITHM=HS256
APP_CONFIG__JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
APP_CONFIG__JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

# Email
APP_CONFIG__EMAIL__SMTP_HOST=smtp.gmail.com
APP_CONFIG__EMAIL__SMTP_PORT=587
APP_CONFIG__EMAIL__SMTP_USERNAME=
APP_CONFIG__EMAIL__SMTP_PASSWORD=
APP_CONFIG__EMAIL__SMTP_TLS=true
APP_CONFIG__EMAIL__FROM_EMAIL=noreply@example.com
APP_CONFIG__EMAIL__FROM_NAME=FastAPI Auth

# Логування
APP_CONFIG__LOGGING__LEVEL=INFO
APP_CONFIG__LOGGING__FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s